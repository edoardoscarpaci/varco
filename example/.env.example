# ── Varco Post Example — environment variables ──────────────────────────────
#
# Copy this file to .env and fill in the values for local development:
#
#   cp .env.example .env
#   # edit .env as needed
#   source .env   # or use direnv / dotenv
#
# When using Docker Compose, environment is set in docker-compose.yml
# directly — this file is for manual / uv-run development.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# asyncpg connection DSN.  Scheme must be "postgresql+asyncpg".
# For the Docker Compose stack: postgresql+asyncpg://varco:varco@localhost:5433/varco
DATABASE_URL=postgresql+asyncpg://varco:varco@localhost:5433/varco

# ── Redis ─────────────────────────────────────────────────────────────────────
# Event bus (Redis Pub/Sub) and cache backend share the same Redis instance
# in the quickstart.  For production, use separate instances or namespaces.
# For the Docker Compose stack: redis://localhost:6380
VARCO_REDIS_URL=redis://localhost:6380
VARCO_REDIS_CACHE_URL=redis://localhost:6380

# ── JWT signing key ───────────────────────────────────────────────────────────
# PEM-encoded RSA or EC private key used to sign JWT access tokens.
# When empty (or unset), the app generates an ephemeral RSA-2048 key at startup.
# ALL TOKENS ARE INVALIDATED ON RESTART in ephemeral mode — users must re-login.
#
# To generate a stable key:
#   openssl genrsa -out jwt_private.pem 2048
#   cat jwt_private.pem
#
# Paste the full PEM (including BEGIN/END lines) as the value below.
# Multi-line values must be quoted if your shell requires it.
VARCO_JWT_PRIVATE_KEY_PEM=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS preflight responses.
# Use "*" for development (allows all origins).
# In production, restrict to your frontend domain(s): https://myapp.example.com
VARCO_CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
# Standard Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Set to DEBUG to see SQL queries (echo=True in SAConfig) and event bus messages.
LOG_LEVEL=INFO
