# ── Varco Post Example — environment variables ──────────────────────────────
#
# Copy this file to .env and fill in the values for local development:
#
#   cp .env.example .env
#   # edit .env as needed
#   source .env   # or use direnv / dotenv
#
# When using Docker Compose, environment is set in docker-compose.yml
# directly — this file is for manual / uv-run development.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (raw URL — used by the example app directly) ────────────────────
# asyncpg connection DSN.  Scheme must be "postgresql+asyncpg".
# For the Docker Compose stack: postgresql+asyncpg://varco:varco@localhost:5433/varco
DATABASE_URL=postgresql+asyncpg://varco:varco@localhost:5433/varco

# ── Database (structured — used by connections.make_engine / make_di_sa_provider)
# Uncomment and fill in these vars if you use PostgresConnectionSettings
# instead of DATABASE_URL.  Nested TLS config uses the __ delimiter.
#
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_DATABASE=varco
# POSTGRES_USERNAME=varco
# POSTGRES_PASSWORD=varco
# POSTGRES_POOL_SIZE=5
# POSTGRES_MAX_OVERFLOW=10
#
# TLS (optional — activate by uncommenting):
# POSTGRES_SSL__CA_CERT=/etc/ssl/postgres-ca.pem
# POSTGRES_SSL__VERIFY=true

# ── Redis (raw URL — used by the example app directly) ───────────────────────
# Event bus (Redis Pub/Sub) and cache backend share the same Redis instance
# in the quickstart.  For production, use separate instances or namespaces.
# For the Docker Compose stack: redis://localhost:6380
VARCO_REDIS_URL=redis://localhost:6380
VARCO_REDIS_CACHE_URL=redis://localhost:6380

# ── Redis (structured — used by connections.make_redis_client) ────────────────
# Uncomment if you use RedisConnectionSettings instead of VARCO_REDIS_URL.
#
# REDIS_HOST=localhost
# REDIS_PORT=6380
# REDIS_DB=0
# REDIS_PASSWORD=
#
# TLS (optional):
# REDIS_SSL__CA_CERT=/etc/ssl/redis-ca.pem
# REDIS_SSL__VERIFY=true

# ── Kafka (structured — used by connections.make_kafka_producer/consumer) ─────
# Uncomment to configure Kafka connection settings.
#
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_GROUP_ID=varco-example
#
# SASL authentication (optional):
# KAFKA_AUTH__TYPE=sasl
# KAFKA_AUTH__MECHANISM=SCRAM-SHA-256
# KAFKA_AUTH__USERNAME=
# KAFKA_AUTH__PASSWORD=
#
# TLS (optional — combine with SASL for SASL_SSL):
# KAFKA_SSL__CA_CERT=/etc/ssl/kafka-ca.pem
# KAFKA_SSL__VERIFY=true

# ── External HTTP APIs (structured — used by connections.make_http_client) ────
# Each external HTTP client has its own prefix.  Add one block per service.
# Replace PAYMENT_API_ with your own prefix (e.g. NOTIF_API_, INVENTORY_API_).
#
# PAYMENT_API_BASE_URL=https://pay.example.com/v1
# PAYMENT_API_TIMEOUT=5.0
# PAYMENT_API_AUTH__TYPE=basic
# PAYMENT_API_AUTH__USERNAME=svc-user
# PAYMENT_API_AUTH__PASSWORD=secret
#
# TLS (optional):
# PAYMENT_API_SSL__CA_CERT=/etc/ssl/pay-ca.pem
# PAYMENT_API_SSL__VERIFY=true

# ── JWT signing key ───────────────────────────────────────────────────────────
# PEM-encoded RSA or EC private key used to sign JWT access tokens.
# When empty (or unset), the app generates an ephemeral RSA-2048 key at startup.
# ALL TOKENS ARE INVALIDATED ON RESTART in ephemeral mode — users must re-login.
#
# To generate a stable key:
#   openssl genrsa -out jwt_private.pem 2048
#   cat jwt_private.pem
#
# Paste the full PEM (including BEGIN/END lines) as the value below.
# Multi-line values must be quoted if your shell requires it.
VARCO_JWT_PRIVATE_KEY_PEM=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS preflight responses.
# Use "*" for development (allows all origins).
# In production, restrict to your frontend domain(s): https://myapp.example.com
VARCO_CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
# Standard Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Set to DEBUG to see SQL queries (echo=True in SAConfig) and event bus messages.
LOG_LEVEL=INFO
